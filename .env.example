# Copy to .env and adjust. Docker Compose reads JWT_SECRET / GOTENBERG_URL from
# here; the api/worker also read these directly when run via `make run-*`.

# --- required ---
DATABASE_URL=postgres://b2b:b2b@localhost:5432/b2b?sslmode=disable
JWT_SECRET=change-me-in-production-please-32-bytes-min

# --- optional (defaults shown) ---
HTTP_PORT=8080
JWT_TTL=24h
ENV=development
LOG_LEVEL=info

# Gotenberg PDF service for invoice rendering. Unset → the worker uses a stub
# renderer (placeholder PDF). Compose sets this to the bundled gotenberg service.
GOTENBERG_URL=http://localhost:3000
