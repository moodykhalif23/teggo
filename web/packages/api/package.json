{
  "name": "@oro/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Typed API client for the oro-folk Go backend, generated from the OpenAPI contract (the single source of truth).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.d.ts"
  },
  "scripts": {
    "generate": "openapi-typescript openapi.yaml -o src/schema.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.0"
  }
}
