{
  "name": "teggo-web",
  "private": true,
  "type": "module",
  "description": "Frontends for the Teggo B2B commerce platform (Vue 3 admin SPA + Nuxt storefront SSR), sharing PrimeVue and a generated API client.",
  "scripts": {
    "dev": "pnpm --parallel --filter @teggo/admin --filter @teggo/storefront run dev",
    "dev:admin": "pnpm --filter @teggo/admin dev",
    "dev:storefront": "pnpm --filter @teggo/storefront dev",
    "docs": "pnpm --filter @teggo/docs start",
    "build": "pnpm -r build",
    "build:admin": "pnpm --filter @teggo/admin build",
    "build:storefront": "pnpm --filter @teggo/storefront build",
    "build:docs": "pnpm --filter @teggo/docs build"
  },
  "engines": {
    "node": ">=20"
  }
}
