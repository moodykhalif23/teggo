{
  "name": "@teggo/docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "copy-spec": "cp ../packages/api/openapi.yaml static/openapi.yaml",
    "gen-api": "docusaurus gen-api-docs all",
    "clean-api": "docusaurus clean-api-docs all",
    "start": "pnpm copy-spec && pnpm gen-api && docusaurus start",
    "build": "pnpm copy-spec && pnpm clean-api && pnpm gen-api && docusaurus build",
    "serve": "docusaurus serve",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@docusaurus/core": "3.8.1",
    "@docusaurus/preset-classic": "3.8.1",
    "@docusaurus/theme-common": "3.8.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.1.0",
    "docusaurus-plugin-openapi-docs": "^4.4.0",
    "docusaurus-theme-openapi-docs": "^4.4.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.8.1",
    "@docusaurus/tsconfig": "3.8.1",
    "@docusaurus/types": "3.8.1",
    "typescript": "~5.6.0"
  },
  "engines": {
    "node": ">=18.0"
  }
}
